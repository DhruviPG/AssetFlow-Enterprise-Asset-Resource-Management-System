# AssetFlow environment template
# Copy this file to `.env` in your deployment environment and provide real values.

FLASK_ENV=development
FLASK_DEBUG=1
ASSETFLOW_SECRET_KEY=change-this-secret
DATABASE_URL=postgresql+psycopg2://assetflow:assetflow@localhost:5432/assetflow

# Optional bootstrap values for the first administrator account.
ASSETFLOW_ADMIN_EMAIL=admin@assetflow.local
ASSETFLOW_ADMIN_PASSWORD=ChangeMe123!
ASSETFLOW_ADMIN_NAME=AssetFlow Administrator
ASSETFLOW_ADMIN_EMPLOYEE_NUMBER=EMP-0001
